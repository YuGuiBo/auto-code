<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.flowable.org/processdef">

    <process id="reimbursementProcess" name="报销申请流程" isExecutable="true">
        
        <!-- 开始事件 -->
        <startEvent id="startEvent" name="开始"/>
        
        <!-- 直接经理审批 -->
        <userTask id="managerApproval" name="直接经理审批" flowable:assignee="manager"/>
        
        <!-- 网关：判断是否需要部门经理审批（基于金额） -->
        <exclusiveGateway id="amountGateway" name="金额判断"/>
        
        <!-- 部门经理审批（仅大额报销） -->
        <userTask id="deptManagerApproval" name="部门经理审批" flowable:assignee="deptManager">
            <extensionElements>
                <flowable:executionListener event="start" expression="${execution.setVariable('status', 'PENDING_DEPT_MANAGER_APPROVAL')}"/>
            </extensionElements>
        </userTask>
        
        <!-- 财务审批 -->
        <userTask id="financeApproval" name="财务审批" flowable:assignee="finance">
            <extensionElements>
                <flowable:executionListener event="start" expression="${execution.setVariable('status', 'PENDING_FINANCE_APPROVAL')}"/>
            </extensionElements>
        </userTask>
        
        <!-- 结束事件 -->
        <endEvent id="endEvent" name="结束"/>
        
        <!-- 连线 -->
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="managerApproval"/>
        <sequenceFlow id="flow2" sourceRef="managerApproval" targetRef="amountGateway"/>
        
        <!-- 金额判断：大于1000需要部门经理审批 -->
        <sequenceFlow id="flow3" name="大额报销(>1000)" sourceRef="amountGateway" targetRef="deptManagerApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${amount > 1000 && managerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 金额判断：小于等于1000直接进财务审批 -->
        <sequenceFlow id="flow4" name="小额报销(≤1000)" sourceRef="amountGateway" targetRef="financeApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${amount <= 1000 && managerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 经理拒绝直接结束 -->
        <sequenceFlow id="flow5" name="经理拒绝" sourceRef="amountGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${managerApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 部门经理审批后的判断 -->
        <exclusiveGateway id="deptManagerGateway" name="部门经理审批结果"/>
        <sequenceFlow id="flow6" sourceRef="deptManagerApproval" targetRef="deptManagerGateway"/>
        
        <!-- 部门经理批准，进入财务审批 -->
        <sequenceFlow id="flow7" name="部门经理批准" sourceRef="deptManagerGateway" targetRef="financeApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${deptManagerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 部门经理拒绝，流程结束 -->
        <sequenceFlow id="flow8" name="部门经理拒绝" sourceRef="deptManagerGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${deptManagerApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 财务审批后的判断 -->
        <exclusiveGateway id="financeGateway" name="财务审批结果"/>
        <sequenceFlow id="flow9" sourceRef="financeApproval" targetRef="financeGateway"/>
        
        <!-- 财务批准或拒绝，流程都结束 -->
        <sequenceFlow id="flow10" name="财务批准" sourceRef="financeGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${financeApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <sequenceFlow id="flow11" name="财务拒绝" sourceRef="financeGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${financeApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
    </process>
    
</definitions>
