<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.flowable.org/processdef">

    <process id="overtimeProcess" name="加班申请流程" isExecutable="true">
        
        <!-- 开始事件 -->
        <startEvent id="startEvent" name="开始"/>
        
        <!-- 直接经理审批 -->
        <userTask id="managerApproval" name="直接经理审批" flowable:assignee="manager"/>
        
        <!-- 网关：判断是否需要部门经理审批（基于加班类型和时长） -->
        <exclusiveGateway id="overtimeTypeGateway" name="加班类型判断"/>
        
        <!-- 部门经理审批（周末/节假日加班或长时间工作日加班） -->
        <userTask id="deptManagerApproval" name="部门经理审批" flowable:assignee="deptManager"/>
        
        <!-- HR确认 -->
        <userTask id="hrConfirmation" name="HR确认" flowable:assignee="hr"/>
        
        <!-- 结束事件 -->
        <endEvent id="endEvent" name="结束"/>
        
        <!-- 连线 -->
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="managerApproval"/>
        <sequenceFlow id="flow2" sourceRef="managerApproval" targetRef="overtimeTypeGateway"/>
        
        <!-- 判断：周末/节假日或长时间工作日加班需要部门经理审批 -->
        <sequenceFlow id="flow3" name="需要部门经理审批" sourceRef="overtimeTypeGateway" targetRef="deptManagerApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${managerApproved == true && (overtimeType == 'WEEKEND' || overtimeType == 'HOLIDAY' || (overtimeType == 'WEEKDAY' && hours > 2))}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 判断：工作日短时间加班直接到HR确认 -->
        <sequenceFlow id="flow4" name="工作日短时间(≤2h)" sourceRef="overtimeTypeGateway" targetRef="hrConfirmation">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${managerApproved == true && overtimeType == 'WEEKDAY' && hours <= 2}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 经理拒绝直接结束 -->
        <sequenceFlow id="flow5" name="经理拒绝" sourceRef="overtimeTypeGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${managerApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 部门经理审批后的判断 -->
        <exclusiveGateway id="deptManagerGateway" name="部门经理审批结果"/>
        <sequenceFlow id="flow6" sourceRef="deptManagerApproval" targetRef="deptManagerGateway"/>
        
        <!-- 部门经理批准，进入HR确认 -->
        <sequenceFlow id="flow7" name="部门经理批准" sourceRef="deptManagerGateway" targetRef="hrConfirmation">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${deptManagerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 部门经理拒绝，流程结束 -->
        <sequenceFlow id="flow8" name="部门经理拒绝" sourceRef="deptManagerGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${deptManagerApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- HR确认后的判断 -->
        <exclusiveGateway id="hrGateway" name="HR确认结果"/>
        <sequenceFlow id="flow9" sourceRef="hrConfirmation" targetRef="hrGateway"/>
        
        <!-- HR确认或拒绝，流程都结束 -->
        <sequenceFlow id="flow10" name="HR确认通过" sourceRef="hrGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${hrApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <sequenceFlow id="flow11" name="HR拒绝" sourceRef="hrGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${hrApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
    </process>
    
</definitions>