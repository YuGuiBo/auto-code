<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.flowable.org/processdef">

    <process id="businessTripProcess" name="出差申请流程" isExecutable="true">
        
        <!-- 开始事件 -->
        <startEvent id="startEvent" name="开始"/>
        
        <!-- 直接经理审批 -->
        <userTask id="managerApproval" name="直接经理审批" flowable:assignee="manager"/>
        
        <!-- 网关：判断是否需要部门经理审批（基于天数） -->
        <exclusiveGateway id="daysGateway" name="天数判断"/>
        
        <!-- 部门经理审批（仅长期出差） -->
        <userTask id="deptManagerApproval" name="部门经理审批" flowable:assignee="deptManager"/>
        
        <!-- 行政审批 -->
        <userTask id="adminApproval" name="行政审批" flowable:assignee="admin"/>
        
        <!-- 结束事件 -->
        <endEvent id="endEvent" name="结束"/>
        
        <!-- 连线 -->
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="managerApproval"/>
        <sequenceFlow id="flow2" sourceRef="managerApproval" targetRef="daysGateway"/>
        
        <!-- 天数判断：大于3天需要部门经理审批 -->
        <sequenceFlow id="flow3" name="长期出差(>3天)" sourceRef="daysGateway" targetRef="deptManagerApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${days > 3 && managerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 天数判断：小于等于3天直接进行政审批 -->
        <sequenceFlow id="flow4" name="短期出差(≤3天)" sourceRef="daysGateway" targetRef="adminApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${days <= 3 && managerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 经理拒绝直接结束 -->
        <sequenceFlow id="flow5" name="经理拒绝" sourceRef="daysGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${managerApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 部门经理审批后的判断 -->
        <exclusiveGateway id="deptManagerGateway" name="部门经理审批结果"/>
        <sequenceFlow id="flow6" sourceRef="deptManagerApproval" targetRef="deptManagerGateway"/>
        
        <!-- 部门经理批准，进入行政审批 -->
        <sequenceFlow id="flow7" name="部门经理批准" sourceRef="deptManagerGateway" targetRef="adminApproval">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${deptManagerApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 部门经理拒绝，流程结束 -->
        <sequenceFlow id="flow8" name="部门经理拒绝" sourceRef="deptManagerGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${deptManagerApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <!-- 行政审批后的判断 -->
        <exclusiveGateway id="adminGateway" name="行政审批结果"/>
        <sequenceFlow id="flow9" sourceRef="adminApproval" targetRef="adminGateway"/>
        
        <!-- 行政批准或拒绝，流程都结束 -->
        <sequenceFlow id="flow10" name="行政批准" sourceRef="adminGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${adminApproved == true}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <sequenceFlow id="flow11" name="行政拒绝" sourceRef="adminGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${adminApproved == false}]]>
            </conditionExpression>
        </sequenceFlow>
        
    </process>
    
</definitions>